# Copy to .env and fill in values for local development
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
LOG_LEVEL=INFO

# Scheduler
SCHEDULER_HZ=5.0        # control loop frequency in Hz

# Safety thresholds
STALE_TIMEOUT_S=5.0     # seconds before a drone is considered stale
LOW_BATTERY_PCT=20.0    # % below which non-landing commands are blocked

# Geofence (metres, local frame)
# Defaults defined in core/config.py — override here if needed
